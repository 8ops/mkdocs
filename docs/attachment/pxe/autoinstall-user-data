#cloud-config
# See the autoinstall documentation at:
# https://canonical-subiquity.readthedocs-hosted.com/en/latest/reference/autoinstall-reference.html
autoinstall:
  apt:
    disable_components: []
    fallback: offline-install
    geoip: true
    timezone: Asia/Shanghai
    mirror-selection:
      primary:
      - uri: https://mirrors.aliyun.com/ubuntu/
      - country-mirror
      - arches: &id001
        - amd64
        - i386
        uri: https://archive.ubuntu.com/ubuntu/
      - arches: &id002
        - s390x
        - arm64
        - armhf
        - powerpc
        - ppc64el
        - riscv64
        uri: https://ports.ubuntu.com/ubuntu-ports
    preserve_sources_list: false
    security:
    - arches: *id001
      uri: https://security.ubuntu.com/ubuntu/
    - arches: *id002
      uri: http://ports.ubuntu.com/ubuntu-ports
  codecs:
    install: false
  drivers:
    install: false
  identity:
    hostname: ubuntu-pxe
    password: $6$C7x6H252Q/jj/8KE$jLt1s7SZPBKJSnoB8RLX3L1xA9BierZCVE/A6SODVwqztiyJx4cllrUrKvOOxf1lSpTrH1U1VyKIhi0qPSE6S0
    realname: root
    username: root
  kernel:
    package: linux-generic
  keyboard:
    layout: us
    toggle: null
    variant: ''
  locale: en_US.UTF-8
  network:
    ethernets:
      ens3:
        addresses:
        - 10.101.11.120/24
        nameservers:
          addresses:
          - 10.101.11.105
          search: []
        routes:
        - to: default
          via: 10.101.11.254
    version: 2
  oem:
    install: auto
  source:
    id: ubuntu-server-minimal
    search_drivers: false
  ssh:
    allow-pw: true
    authorized-keys: ['ssh-rsa  pro-ansible-root-key']
    install-server: true
  updates: security
  version: 1
  storage:
    config:
      - type: disk
        id: disk-vda
        path: /dev/vda
        ptable: gpt
        wipe: superblock-recursive
        grub_device: true
      - type: disk
        id: disk-vdb
        path: /dev/vdb
        ptable: gpt
        wipe: superblock-recursive
      - type: partition
        id: bios_grub
        device: disk-vda
        size: 2MB
        flag: bios_grub
      - type: partition
        id: boot-part
        device: disk-vda
        size: 1GB
      - type: format
        id: boot-fs
        volume: boot-part
        fstype: ext4
      - type: mount
        id: mount-boot
        device: boot-fs
        path: /boot
      - type: partition
        id: root-part
        device: disk-vda
        size: -1
      - type: partition
        id: data-part
        device: disk-vdb
        size: -1
      - type: format
        id: root-fs
        volume: root-part
        fstype: xfs
      - type: format
        id: data-fs
        volume: data-part
        fstype: xfs
      - type: mount
        id: mount-root
        device: root-fs
        path: /
      - type: mount
        id: mount-data
        device: data-fs
        path: /data
  packages:
    - iputils-ping
    - vim
    - tree
  late-commands:
    - curtin in-target -- grub-install --target=i386-pc /dev/vda
    - curtin in-target -- update-grub
    - curtin in-target -- sed -i 's/^#Port 22/Port 12622/' /etc/ssh/sshd_config
    - curtin in-target -- systemctl disable systemd-resolved
    - curtin in-target -- sed -i 's/^#DNS=/DNS=10.101.11.254/' /etc/systemd/resolved.conf
    - curtin in-target -- rm -f /etc/resolv.conf && echo 'nameserver 10.101.11.254' > /etc/resolv.conf 
    - curtin in-target -- sed -i 's/^#NTP=/NTP=ntp.8ops.top/' /etc/systemd/timesyncd.conf
